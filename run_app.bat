@echo off
title AI Contour - Быстрый запуск
chcp 65001 > nul

:: ==============================================================================
:: Скрипт быстрого запуска приложения AI Contour в Windows
:: ==============================================================================
:: cd /d "%~dp0" гарантирует переход в директорию расположения этого bat-файла,
:: даже если он запускается из другой папки или через ярлык.
cd /d "%~dp0"

:: Проверка наличия виртуального окружения
if not exist "venv\Scripts\pythonw.exe" (
    echo [ОШИБКА] Виртуальное окружение venv не найдено в папке "%~dp0"!
    echo Пожалуйста, выполните установку зависимостей согласно README.md.
    echo.
    pause
    exit /b 1
)

:: Запуск приложения через pythonw.exe (без отображения черного окна консоли)
start "" "venv\Scripts\pythonw.exe" auto_contour.py
exit /b 0
